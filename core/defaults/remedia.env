# core/defaults/remedia.env

# Remedia default configuration
# This file is managed by package. Do not edit.

# -----------------------------
# STORAGE LAYOUT
# -----------------------------
FAST_STORAGE=/mnt/shotcut
SLOW_STORAGE=/mnt/storage
BACKUP_STORAGE=/mnt/backups

# -----------------------------
# BACKUPKIT
# -----------------------------
BACKUP_ROOT=/var/lib/remedia/backups
SNAPSHOT_RETENTION=7

# -----------------------------
# RUNTIME
# -----------------------------
LOG_DIR=/var/log/remedia
LIB_DIR=/usr/lib/remedia

# -----------------------------
# PERFORMANCE
# -----------------------------
RSYNC_OPTS=-rlptD --partial --ignore-errors --no-owner

# -----------------------------
# FEATURES
# -----------------------------
ENABLE_CUDA=auto
ENABLE_SCRUB=true

# -----------------------------
# INTERNAL
# -----------------------------
CONFIG_VERSION=1
